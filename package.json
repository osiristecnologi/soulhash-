{
  "name": "soulhash",
  "version": "1.0.0",
  "description": "SoulHash - Web3 card game com integração Phantom Wallet e economia Hash",
  "main": "server.js",

  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",

    "prod": "NODE_ENV=production node server.js",

    "test": "node -e \"fetch('http://localhost:3000/health').then(r=>r.json()).then(console.log).catch(console.error)\"",

    "health": "node -e \"fetch('https://soulhash-api.onrender.com/health').then(r=>r.json()).then(console.log).catch(console.error)\""
  },

  "keywords": [
    "solana",
    "web3",
    "phantom",
    "crypto-game",
    "play-to-earn",
    "blockchain-game",
    "cards",
    "arena"
  ],

  "author": "SoulHash Team",
  "license": "MIT",

  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "dotenv": "^16.3.1",
    "bs58": "^5.0.0"
  },

  "devDependencies": {
    "nodemon": "^3.0.2"
  },

  "engines": {
    "node": ">=18.0.0"
  }
}
